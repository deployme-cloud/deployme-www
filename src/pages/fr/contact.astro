---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t("contact.title") as string}>
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold text-foreground">{t("contact.title")}</h1>
        <p class="mt-4 text-lg text-muted-foreground">{t("contact.subtitle")}</p>
      </div>

      <div class="mt-16 mx-auto max-w-xl">
        <form class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium text-foreground">
              {t("contact.form.name")}
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="mt-2 block w-full rounded-md border border-border bg-background px-4 py-2 text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-foreground">
              {t("contact.form.email")}
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="mt-2 block w-full rounded-md border border-border bg-background px-4 py-2 text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-foreground">
              {t("contact.form.message")}
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="mt-2 block w-full rounded-md border border-border bg-background px-4 py-2 text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full rounded-md bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
          >
            {t("contact.form.submit")}
          </button>
        </form>

        <div class="mt-8 text-center">
          <a
            href="https://discord.gg/deployme"
            class="text-sm text-primary hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t("contact.discord")}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
