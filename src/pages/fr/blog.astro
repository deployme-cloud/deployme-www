---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t("blog.title") as string}>
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold text-foreground">{t("blog.title")}</h1>
        <p class="mt-4 text-lg text-muted-foreground">{t("blog.subtitle")}</p>
      </div>
      <div class="mt-16 text-center">
        <p class="text-muted-foreground">{t("blog.comingSoon")}</p>
      </div>
    </div>
  </section>
</BaseLayout>
