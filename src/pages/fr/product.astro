---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const phases = [
  { title: t("product.phase0.title"), desc: t("product.phase0.desc"), badge: "Phase 0" },
  { title: t("product.phase1.title"), desc: t("product.phase1.desc"), badge: "Phase 1" },
  { title: t("product.phase2.title"), desc: t("product.phase2.desc"), badge: "Phase 2" },
  { title: t("product.phase3.title"), desc: t("product.phase3.desc"), badge: "Phase 3" },
];
---

<BaseLayout title={t("product.title") as string}>
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold text-foreground">{t("product.title")}</h1>
        <p class="mt-4 text-lg text-muted-foreground">{t("product.subtitle")}</p>
      </div>

      <div class="mt-16">
        <h2 class="text-center text-2xl font-bold text-foreground">{t("product.phases.title")}</h2>
        <div class="mt-8 grid gap-6 sm:grid-cols-2">
          {phases.map((phase) => (
            <div class="rounded-lg border border-border bg-card p-6 shadow-sm">
              <span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
                {phase.badge}
              </span>
              <h3 class="mt-3 text-lg font-semibold text-foreground">{phase.title}</h3>
              <p class="mt-2 text-sm text-muted-foreground">{phase.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-16 text-center">
        <h2 class="text-2xl font-bold text-foreground">{t("product.tools.title")}</h2>
        <p class="mt-4 text-muted-foreground">{t("product.tools.subtitle")}</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          {["Go SDK", "Python SDK", "TypeScript SDK", "Terraform", "Ansible", "CAPI", "CLI"].map((tool) => (
            <span class="rounded-full border border-border bg-secondary px-4 py-2 text-sm font-medium text-foreground">
              {tool}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
