---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  {
    title: t("home.features.simple.title"),
    desc: t("home.features.simple.desc"),
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`,
  },
  {
    title: t("home.features.secure.title"),
    desc: t("home.features.secure.desc"),
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`,
  },
  {
    title: t("home.features.flexible.title"),
    desc: t("home.features.flexible.desc"),
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25" />`,
  },
  {
    title: t("home.features.open.title"),
    desc: t("home.features.open.desc"),
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />`,
  },
];
---

<BaseLayout title="Kubernetes as a Service">
  <Hero />

  <!-- Features -->
  <section class="relative py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl" style="font-family: var(--font-heading)">
          {t("home.features.title")}
        </h2>
      </div>

      <div class="mt-16 grid gap-6 sm:grid-cols-2">
        {features.map((feature) => (
          <div class="group relative rounded-xl border border-border/50 bg-card p-8 transition-all duration-200 hover:border-border hover:shadow-sm">
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
              <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <Fragment set:html={feature.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-foreground" style="font-family: var(--font-heading)">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative border-t border-border/50 bg-muted/30 py-24">
    <div class="mx-auto max-w-6xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl" style="font-family: var(--font-heading)">
        {t("home.cta.title")}
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">{t("home.cta.subtitle")}</p>
      <a
        href="https://app.deployme.cloud"
        class="mt-8 inline-flex items-center justify-center rounded-lg bg-accent px-8 py-3 text-sm font-semibold text-accent-foreground transition-all hover:brightness-110"
      >
        {t("home.cta.button")}
        <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
