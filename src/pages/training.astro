---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const freeItems = t("training.free.items");
const proItems = t("training.pro.items");
---

<BaseLayout title={t("training.title") as string}>
  <!-- Hero -->
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl" style="font-family: var(--font-heading)">
          {t("training.title")}
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-muted-foreground">{t("training.subtitle")}</p>
      </div>
    </div>
  </section>

  <!-- Cards -->
  <section class="border-t border-border/50 bg-muted/30 py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Free -->
        <div class="rounded-xl border border-border/50 bg-card p-8 transition-all duration-200 hover:border-border hover:shadow-sm">
          <div class="mb-6 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-foreground" style="font-family: var(--font-heading)">{t("training.free.title")}</h2>
          <ul class="mt-6 space-y-3">
            {Array.isArray(freeItems) &&
              (freeItems as string[]).map((item: string) => (
                <li class="flex items-start gap-3 text-sm text-muted-foreground">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  {item}
                </li>
              ))}
          </ul>
        </div>

        <!-- Pro -->
        <div class="rounded-xl border border-accent/30 bg-card p-8 shadow-md ring-1 ring-accent/10 transition-all duration-200 hover:shadow-lg">
          <div class="mb-6 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-foreground" style="font-family: var(--font-heading)">{t("training.pro.title")}</h2>
          <ul class="mt-6 space-y-3">
            {Array.isArray(proItems) &&
              (proItems as string[]).map((item: string) => (
                <li class="flex items-start gap-3 text-sm text-muted-foreground">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  {item}
                </li>
              ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
