---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const plans = [
  {
    title: t("pricing.community.title"),
    price: t("pricing.community.price"),
    desc: t("pricing.community.desc"),
    features: t("pricing.community.features"),
    cta: t("pricing.cta"),
    href: "https://app.deployme.cloud",
    highlighted: false,
  },
  {
    title: t("pricing.pro.title"),
    price: t("pricing.pro.price"),
    desc: t("pricing.pro.desc"),
    features: t("pricing.pro.features"),
    cta: t("pricing.cta"),
    href: "https://app.deployme.cloud",
    highlighted: true,
  },
  {
    title: t("pricing.enterprise.title"),
    price: t("pricing.enterprise.price"),
    desc: t("pricing.enterprise.desc"),
    features: t("pricing.enterprise.features"),
    cta: t("pricing.contact"),
    href: "mailto:contact@deployme.cloud",
    highlighted: false,
  },
];
---

<BaseLayout title={t("pricing.title") as string}>
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl" style="font-family: var(--font-heading)">
          {t("pricing.title")}
        </h1>
        <p class="mt-6 text-lg text-muted-foreground">{t("pricing.subtitle")}</p>
      </div>

      <div class="mt-16 grid gap-6 lg:grid-cols-3">
        {plans.map((plan) => (
          <div
            class:list={[
              "relative flex flex-col rounded-xl border p-8 transition-all duration-200",
              plan.highlighted
                ? "border-accent bg-card shadow-md ring-1 ring-accent/20"
                : "border-border/50 bg-card hover:border-border hover:shadow-sm",
            ]}
          >
            {plan.highlighted && (
              <div class="absolute -top-3 left-6 inline-flex items-center rounded-full bg-accent px-3 py-1 text-xs font-semibold text-accent-foreground">
                Popular
              </div>
            )}
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">{plan.title}</h3>
              <p class="mt-3 text-3xl font-bold tracking-tight text-foreground" style="font-family: var(--font-heading)">{plan.price}</p>
              <p class="mt-2 text-sm text-muted-foreground">{plan.desc}</p>
            </div>

            <ul class="mt-8 flex-1 space-y-3">
              {Array.isArray(plan.features) &&
                (plan.features as string[]).map((feature: string) => (
                  <li class="flex items-start gap-3 text-sm text-muted-foreground">
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    {feature}
                  </li>
                ))}
            </ul>

            <a
              href={plan.href}
              class:list={[
                "mt-8 block rounded-lg px-4 py-2.5 text-center text-sm font-semibold transition-all",
                plan.highlighted
                  ? "bg-accent text-accent-foreground hover:brightness-110"
                  : "border border-border bg-background text-foreground hover:bg-muted",
              ]}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
