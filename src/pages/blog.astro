---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t("blog.title") as string}>
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl" style="font-family: var(--font-heading)">
          {t("blog.title")}
        </h1>
        <p class="mt-6 text-lg text-muted-foreground">{t("blog.subtitle")}</p>
      </div>
      <div class="mt-16 flex items-center justify-center rounded-xl border border-dashed border-border/50 bg-muted/20 py-24">
        <p class="text-sm text-muted-foreground">{t("blog.comingSoon")}</p>
      </div>
    </div>
  </section>
</BaseLayout>
