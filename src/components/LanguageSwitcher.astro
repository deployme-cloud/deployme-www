---
import { languages, getLangFromUrl } from "@/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const pathname = Astro.url.pathname;

function getTargetPath(targetLang: string): string {
  const pathWithoutLang = pathname.replace(/^\/(en|fr)/, "") || "/";
  if (targetLang === "en") return pathWithoutLang;
  return `/${targetLang}${pathWithoutLang}`;
}
---

<div class="flex items-center gap-0.5 text-sm">
  {Object.entries(languages).map(([code, label]) => (
    <a
      href={getTargetPath(code)}
      class:list={[
        "rounded-md px-2 py-1 text-xs transition-colors",
        code === lang
          ? "bg-muted font-semibold text-foreground"
          : "text-muted-foreground hover:text-foreground",
      ]}
    >
      {code.toUpperCase()}
    </a>
  ))}
</div>
