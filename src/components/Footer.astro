---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "@/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="border-t border-border bg-secondary/50">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <div>
        <h3 class="text-sm font-semibold text-foreground">{t("footer.product")}</h3>
        <ul class="mt-4 space-y-2">
          <li><a href={getLocalizedPath(lang, "/product")} class="text-sm text-muted-foreground hover:text-foreground">{t("nav.product")}</a></li>
          <li><a href={getLocalizedPath(lang, "/pricing")} class="text-sm text-muted-foreground hover:text-foreground">{t("nav.pricing")}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-foreground">{t("footer.resources")}</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="https://docs.deployme.cloud" class="text-sm text-muted-foreground hover:text-foreground" target="_blank" rel="noopener noreferrer">{t("nav.docs")}</a></li>
          <li><a href={getLocalizedPath(lang, "/blog")} class="text-sm text-muted-foreground hover:text-foreground">{t("nav.blog")}</a></li>
          <li><a href={getLocalizedPath(lang, "/training")} class="text-sm text-muted-foreground hover:text-foreground">{t("nav.training")}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-foreground">{t("footer.company")}</h3>
        <ul class="mt-4 space-y-2">
          <li><a href={getLocalizedPath(lang, "/about")} class="text-sm text-muted-foreground hover:text-foreground">{t("nav.about")}</a></li>
          <li><a href={getLocalizedPath(lang, "/contact")} class="text-sm text-muted-foreground hover:text-foreground">{t("nav.contact")}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-foreground">{t("footer.legal")}</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="#" class="text-sm text-muted-foreground hover:text-foreground">{t("footer.privacy")}</a></li>
          <li><a href="#" class="text-sm text-muted-foreground hover:text-foreground">{t("footer.terms")}</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-8 border-t border-border pt-8">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <div class="flex items-center gap-3">
          <img src="/brand/deployme-icon-rounded.svg" alt="Deployme.cloud" class="h-6 w-6" />
          <p class="text-sm text-muted-foreground">{t("footer.tagline")}</p>
        </div>
        <p class="text-sm text-muted-foreground">{t("footer.copyright")}</p>
      </div>
    </div>
  </div>
</footer>
